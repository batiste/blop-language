{
  "manifest_version": 3,
  "name": "Blop DevTools (MVP)",
  "description": "Minimal DevTools panel to inspect the Blop component tree.",
  "version": "0.0.1",
  "devtools_page": "devtools.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script.js"],
      "run_at": "document_start"
    }
  ]
}
